# =========================
# SafeToSpend env template
# =========================
# Copy this file to .env and fill real values.
# Never commit your real .env.

# -------------------------
# Core app (required)
# -------------------------
APP_ENV=development
SQLALCHEMY_DATABASE_URI=postgresql+psycopg://user:password@localhost:5432/safetospend
# Alternative DB variable (use one of the two):
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/safetospend

SECRET_KEY=replace-with-long-random-secret
ALLOW_INSECURE_DEV_SECRET_KEY=0

# Session / proxy
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=false
PERMANENT_SESSION_LIFETIME_SECONDS=43200
TRUST_PROXY_X_FORWARDED_FOR=false

# -------------------------
# Upload / receipt
# -------------------------
EVIDENCE_UPLOAD_DIR=./uploads/evidence
MAX_UPLOAD_BYTES=20971520
MAX_REQUEST_BYTES=104857600
RECEIPT_BATCH_DELAY_SECONDS=45
RECEIPT_BATCH_WORKER_CHECK_SECONDS=30
RECEIPT_BATCH_STALE_MINUTES=5

# -------------------------
# Admin
# -------------------------
# 관리자 권한은 환경변수 이메일 fallback으로 주지 않습니다.
# 일반 계정을 만든 뒤 아래 CLI로 명시적으로 권한을 부여하세요.
# flask --app app set-admin-role --email admin@example.com --grant

# -------------------------
# Optional infra tuning
# -------------------------
RATE_LIMIT_REDIS_URL=
ASSET_REFRESH_RETRY_SECONDS=21600
NHIS_REFRESH_RETRY_SECONDS=21600

# -------------------------
# OpenAI (receipt parsing)
# -------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# -------------------------
# Popbill (bank sync)
# -------------------------
POPBILL_LINK_ID=
POPBILL_SECRET_KEY=
POPBILL_CORP_NUM=
POPBILL_USER_ID=
POPBILL_IS_TEST=true

# -------------------------
# Toss billing
# -------------------------
TOSS_PAYMENTS_CLIENT_KEY=
TOSS_PAYMENTS_SECRET_KEY=
TOSS_PAYMENTS_API_BASE_URL=https://api.tosspayments.com

# Billing key encryption (required for billing features)
BILLING_KEY_ENCRYPTION_SECRET=replace-with-16plus-random-secret
BILLING_KEY_ACTIVE_VERSION=v1
# Optional versioned keys for rotation:
# BILLING_KEY_ENCRYPTION_SECRET_V1=
# BILLING_KEY_ENCRYPTION_SECRET_V2=

# Billing startup guard: off | warn | strict
BILLING_GUARD_MODE=warn
